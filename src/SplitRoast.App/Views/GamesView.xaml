<UserControl x:Class="SplitRoast.App.Views.GamesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:SplitRoast.App.Converters"
             xmlns:vm="clr-namespace:SplitRoast.App.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:GamesViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
        <conv:SuitabilityToBrushConverter x:Key="SuitBrush" />

        <!--
            Tile button: a chrome-less button so the whole tile is clickable, with
            a hover lift (border + slight scale) for feedback.
        -->
        <Style x:Key="TileButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="9" />
            <Setter Property="Width" Value="190" />
            <Setter Property="Height" Value="285" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" CornerRadius="8" SnapsToDevicePixels="True"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="Transparent" BorderThickness="2"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="Scale" ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush"
                                        Value="{StaticResource AccentBrush}" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Scale"
                                                Storyboard.TargetProperty="ScaleX" To="1.03" Duration="0:0:0.12" />
                                            <DoubleAnimation Storyboard.TargetName="Scale"
                                                Storyboard.TargetProperty="ScaleY" To="1.03" Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Scale"
                                                Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12" />
                                            <DoubleAnimation Storyboard.TargetName="Scale"
                                                Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,18,24,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page heading + suitability legend -->
        <StackPanel Grid.Row="0" Margin="9,0,0,16">
            <TextBlock Text="My Games" Style="{StaticResource PageTitleStyle}" />
            <WrapPanel Margin="0,10,0,0">
                <WrapPanel.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                        <Setter Property="FontSize" Value="11.5" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                    </Style>
                    <Style TargetType="Border" x:Key="Dot">
                        <Setter Property="Width" Value="9" />
                        <Setter Property="Height" Value="9" />
                        <Setter Property="CornerRadius" Value="4.5" />
                        <Setter Property="Margin" Value="0,0,5,0" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                    </Style>
                </WrapPanel.Resources>
                <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                    <Border Style="{StaticResource Dot}" Background="{StaticResource SuitGoodBrush}" />
                    <TextBlock Text="Online co-op — ideal" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                    <Border Style="{StaticResource Dot}" Background="{StaticResource SuitNativeBrush}" />
                    <TextBlock Text="Native split-screen — not needed" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                    <Border Style="{StaticResource Dot}" Background="{StaticResource SuitMaybeBrush}" />
                    <TextBlock Text="Multiplayer — maybe" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                    <Border Style="{StaticResource Dot}" Background="{StaticResource SuitBadBrush}" />
                    <TextBlock Text="Single-player — won't work" />
                </StackPanel>
            </WrapPanel>
        </StackPanel>

        <!-- Responsive tile grid. HorizontalScrollBarVisibility=Disabled forces the
             WrapPanel to wrap to the viewport width, so the number of tiles per row
             changes with the window size and there is never a horizontal scrollbar. -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled" Padding="0,0,0,16">
            <ItemsControl ItemsSource="{Binding Games}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:GameTileViewModel}">
                        <Button Style="{StaticResource TileButtonStyle}"
                                ToolTip="{Binding Title}"
                                Command="{Binding DataContext.SelectGameCommand,
                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}">
                            <Grid>
                                <!-- Cover image (full-bleed) -->
                                <Image Source="{Binding Cover}" Stretch="UniformToFill"
                                       Visibility="{Binding HasCover, Converter={StaticResource BoolToVis}}">
                                    <Image.Clip>
                                        <RectangleGeometry Rect="0,0,186,281" RadiusX="6" RadiusY="6" />
                                    </Image.Clip>
                                </Image>

                                <!-- Placeholder shown until/if no cover is available -->
                                <Border CornerRadius="6" Background="{StaticResource SurfaceAltBrush}"
                                        Visibility="{Binding HasCover, Converter={StaticResource InverseBoolToVis}}">
                                    <TextBlock Text="{Binding Title}" TextWrapping="Wrap"
                                               TextAlignment="Center" Margin="14"
                                               VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                </Border>

                                <!-- Co-op suitability badge (top-left corner) -->
                                <Border VerticalAlignment="Top" HorizontalAlignment="Left" Margin="6"
                                        CornerRadius="4" Padding="7,3"
                                        Background="{Binding Suitability, Converter={StaticResource SuitBrush}}"
                                        Visibility="{Binding HasBadge, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding BadgeText}" FontSize="10.5"
                                               FontWeight="SemiBold" Foreground="#FF10241D" />
                                </Border>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Loading overlay -->
        <TextBlock Grid.Row="1" Text="Scanning Steam library..." HorizontalAlignment="Center"
                   VerticalAlignment="Center" FontSize="16"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

        <!-- Empty state -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="No Steam games found" FontSize="18" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
            <TextBlock Text="Make sure Steam is installed and you have games downloaded."
                       Margin="0,8,0,0" HorizontalAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}" />
        </StackPanel>
    </Grid>
</UserControl>
